alias ls='ls -F --color=auto --show-control-chars'
alias ll='ls -l'
alias got="git"
alias gs="git status"
alias gco="git checkout"
alias gc="git commit"
alias gcm="git commit -m"
alias gcob="git checkout -b"
alias ga="git add"
alias gd="git diff"
alias gitpushu="git push -u origin HEAD"
alias gitmergemain="gco main && git pull && gco - && git merge main"

alias gorepos=""
alias setproxy=""
alias unsetproxy=""
